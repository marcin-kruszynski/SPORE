{
  "type": "object",
  "required": ["id", "name", "triggerType", "applicableProjectTypes", "roleSequence", "reviewStep", "retryPolicy", "documentationUpdatePolicy", "completionRequirements"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "triggerType": { "type": "string" },
    "applicableProjectTypes": { "type": "array", "items": { "type": "string" } },
    "roleSequence": { "type": "array", "items": { "type": "string" } },
    "stepSets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["roles"],
        "properties": {
          "name": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "gate": {
            "type": "object",
            "properties": {
              "mode": { "type": "string", "enum": ["all", "any", "min_success_count"] },
              "count": { "type": "integer" }
            }
          }
        }
      }
    },
    "branchingConditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["if", "then"],
        "properties": {
          "if": { "type": "string" },
          "then": { "type": "string" }
        }
      }
    },
    "reviewStep": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "retryPolicy": {
      "type": "object",
      "properties": {
        "maxAttempts": { "type": "integer" }
      }
    },
    "documentationUpdatePolicy": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" }
      }
    },
    "completionRequirements": { "type": "array", "items": { "type": "string" } }
  }
}
