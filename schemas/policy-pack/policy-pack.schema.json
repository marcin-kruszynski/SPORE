{
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "workflowPolicy": {
      "type": "object",
      "properties": {
        "defaultRoles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultMaxAttempts": { "type": "integer" },
        "retryTargetRole": { "type": "string" },
        "resetDescendantSteps": { "type": "boolean" },
        "reworkStrategy": { "type": "string" },
        "reworkRoles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxAttemptsByRole": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "stepSoftTimeoutMs": { "type": "integer" },
        "stepHardTimeoutMs": { "type": "integer" },
        "reviewRequired": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "runtimePolicy": {
      "type": "object",
      "properties": {
        "sessionModeByRole": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "workspace": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "enabledRoles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "disabledRoles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "safeMode": { "type": "boolean" }
          }
        }
      }
    },
    "docsKbPolicy": {
      "type": "object",
      "properties": {
        "resultLimit": { "type": "integer" },
        "queryTemplate": { "type": "string" },
        "queryTerms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "coordinationPolicy": {
      "type": "object",
      "properties": {
        "autoHoldParentOnOpenChildEscalation": { "type": "boolean" },
        "resumeParentWhenChildrenSettled": { "type": "boolean" },
        "autoHoldParentOnOpenPromotionEscalation": { "type": "boolean" },
        "resumeParentWhenPromotionSettled": { "type": "boolean" },
        "maxHeldMs": { "type": "integer" },
        "escalateOnFamilyStallMs": { "type": "integer" }
      }
    },
    "selfWorkPolicy": {
      "type": "object",
      "properties": {
        "allowedPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedWorkKinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiresProposalArtifacts": { "type": "boolean" },
        "requiresReview": { "type": "boolean" },
        "requiresHumanApproval": { "type": "boolean" },
        "safeModeDefault": { "type": "boolean" },
        "autonomousEligible": { "type": "boolean" },
        "allowedAutonomousTemplates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedAutonomousMutationScopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "protectedScopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredAutonomousValidationBundles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rolloutTiers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "enabled": { "type": "boolean" },
              "allowedTemplates": {
                "type": "array",
                "items": { "type": "string" }
              },
              "allowedDomains": {
                "type": "array",
                "items": { "type": "string" }
              },
              "allowedMutationScopes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "targetPaths": {
                "type": "array",
                "items": { "type": "string" }
              },
              "protectedScopes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "requireSafeMode": { "type": "boolean" },
              "autoPromoteToIntegration": { "type": "boolean" },
              "requiredValidationBundles": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "intakePriorityPolicy": {
          "type": "object",
          "properties": {
            "learningFailure": { "type": "number" },
            "learningSuccess": { "type": "number" },
            "docSuggestionPending": { "type": "number" },
            "docSuggestionAccepted": { "type": "number" },
            "integrationIssue": { "type": "number" },
            "policyRecommendation": { "type": "number" },
            "highSeverityBonus": { "type": "number" },
            "acceptedBonus": { "type": "number" },
            "blockedBonus": { "type": "number" },
            "promotionBlockedBonus": { "type": "number" },
            "quarantineBonus": { "type": "number" }
          }
        },
        "quarantineThresholds": {
          "type": "object",
          "properties": {
            "failureCount": { "type": "integer" },
            "blockedCount": { "type": "integer" }
          }
        }
      }
    }
  }
}
