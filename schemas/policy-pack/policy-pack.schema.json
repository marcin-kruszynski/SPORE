{
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "workflowPolicy": {
      "type": "object",
      "properties": {
        "defaultRoles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultMaxAttempts": { "type": "integer" },
        "retryTargetRole": { "type": "string" },
        "resetDescendantSteps": { "type": "boolean" },
        "reworkStrategy": { "type": "string" },
        "reworkRoles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxAttemptsByRole": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "stepSoftTimeoutMs": { "type": "integer" },
        "stepHardTimeoutMs": { "type": "integer" },
        "reviewRequired": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "runtimePolicy": {
      "type": "object",
      "properties": {
        "sessionModeByRole": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "workspace": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "enabledRoles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "disabledRoles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "safeMode": { "type": "boolean" }
          }
        }
      }
    },
    "docsKbPolicy": {
      "type": "object",
      "properties": {
        "resultLimit": { "type": "integer" },
        "queryTemplate": { "type": "string" },
        "queryTerms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "coordinationPolicy": {
      "type": "object",
      "properties": {
        "autoHoldParentOnOpenChildEscalation": { "type": "boolean" },
        "resumeParentWhenChildrenSettled": { "type": "boolean" },
        "autoHoldParentOnOpenPromotionEscalation": { "type": "boolean" },
        "resumeParentWhenPromotionSettled": { "type": "boolean" },
        "maxHeldMs": { "type": "integer" },
        "escalateOnFamilyStallMs": { "type": "integer" }
      }
    },
    "selfWorkPolicy": {
      "type": "object",
      "properties": {
        "allowedPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedWorkKinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiresProposalArtifacts": { "type": "boolean" },
        "requiresReview": { "type": "boolean" },
        "requiresHumanApproval": { "type": "boolean" },
        "safeModeDefault": { "type": "boolean" }
      }
    }
  }
}
