{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spore/session-control-event",
  "title": "SPORE Session Control Event",
  "type": "object",
  "required": ["id", "type", "timestamp", "runId", "sessionId", "agentIdentityId", "payload"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "session.stop_requested",
        "session.complete_requested",
        "session.steer"
      ]
    },
    "timestamp": { "type": "string" },
    "runId": { "type": "string" },
    "sessionId": { "type": "string" },
    "projectId": { "type": ["string", "null"] },
    "domainId": { "type": ["string", "null"] },
    "workflowId": { "type": ["string", "null"] },
    "agentIdentityId": { "type": "string" },
    "payload": {
      "type": "object"
    }
  }
}
