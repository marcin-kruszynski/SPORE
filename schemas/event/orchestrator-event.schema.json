{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spore/orchestrator-event.schema.json",
  "title": "SPORE Orchestrator Event",
  "type": "object",
  "required": ["id", "type", "timestamp", "runId"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "runId": { "type": "string" },
    "projectId": { "type": "string" },
    "workflowId": { "type": "string" },
    "status": { "type": "string" },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
