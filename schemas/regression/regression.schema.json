{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "label", "scenarios", "realPiRequired", "stopOnFailure", "concurrency", "timeoutMs", "artifactRetention"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "scenarios": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "realPiRequired": { "type": "boolean" },
    "stopOnFailure": { "type": "boolean" },
    "concurrency": { "type": "integer", "minimum": 1 },
    "timeoutMs": { "type": "integer", "minimum": 1 },
    "artifactRetention": { "type": "string", "enum": ["minimal", "default", "full"] },
    "historyRetentionDays": { "type": "integer", "minimum": 1 },
    "retainFailedRuns": { "type": "boolean" },
    "schedule": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "cronLike": { "type": "string", "minLength": 1 },
        "maxParallelRuns": { "type": "integer", "minimum": 1 },
        "skipIfRunActive": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "tags": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
