{
  "type": "object",
  "required": ["id", "name", "leadProfile", "defaultBuilderProfile", "defaultScoutProfile", "defaultTesterProfile", "defaultReviewerProfile", "tools", "skills", "workflowDefaults"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "taskClass": { "type": "string" },
    "pathPrefixes": { "type": "array", "items": { "type": "string" } },
    "policyPacks": { "type": "array", "items": { "type": "string" } },
    "leadProfile": { "type": "string" },
    "defaultBuilderProfile": { "type": "string" },
    "defaultScoutProfile": { "type": "string" },
    "defaultTesterProfile": { "type": "string" },
    "defaultReviewerProfile": { "type": "string" },
    "tools": { "type": "array", "items": { "type": "string" } },
    "skills": { "type": "array", "items": { "type": "string" } },
    "workflowDefaults": { "type": "array", "items": { "type": "string" } },
    "workflowPolicy": {
      "type": "object",
      "properties": {
        "stepSoftTimeoutMs": { "type": "integer" },
        "stepHardTimeoutMs": { "type": "integer" },
        "defaultMaxAttempts": { "type": "integer" },
        "defaultRoles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retryTargetRole": { "type": "string" },
        "resetDescendantSteps": { "type": "boolean" },
        "reworkStrategy": { "type": "string" },
        "reworkRoles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxAttemptsByRole": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "reviewRequired": { "type": "boolean" },
        "approvalRequired": { "type": "boolean" }
      }
    },
    "runtimePolicy": {
      "type": "object",
      "properties": {
        "defaultBackendKind": { "type": "string" },
        "backendKindByRole": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "sessionModeByRole": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "workspace": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "enabledRoles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "disabledRoles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "safeMode": { "type": "boolean" }
          }
        }
      }
    },
    "docsKbPolicy": {
      "type": "object",
      "properties": {
        "resultLimit": { "type": "integer" },
        "queryTemplate": { "type": "string" },
        "queryTerms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "coordinationPolicy": {
      "type": "object",
      "properties": {
        "autoHoldParentOnOpenChildEscalation": { "type": "boolean" },
        "resumeParentWhenChildrenSettled": { "type": "boolean" },
        "autoHoldParentOnOpenPromotionEscalation": { "type": "boolean" },
        "resumeParentWhenPromotionSettled": { "type": "boolean" },
        "maxHeldMs": { "type": "integer" },
        "escalateOnFamilyStallMs": { "type": "integer" }
      }
    }
  }
}
