{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "label"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "scenarios": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "regressions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requiredForProposalReadiness": { "type": "boolean" },
    "requiredForPromotionReadiness": { "type": "boolean" },
    "allowedAutoSkip": { "type": "boolean" },
    "allowedFailureClassifications": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "maxDurationMs": { "type": "integer", "minimum": 0 },
    "appliesToTemplates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "appliesToMutationScopes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "appliesToProjectRoles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
