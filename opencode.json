{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/home/antman/.config/opencode/get-shit-done/**": "allow"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "agent": {
    "gsd-planner": {
      "model": "openai/gpt-5.4"
    },
    "gsd-plan-checker": {
      "model": "openai/gpt-5.4"
    },
    "gsd-phase-researcher": {
      "model": "openai/gpt-5.4"
    },
    "gsd-roadmapper": {
      "model": "openai/gpt-5.4"
    },
    "gsd-project-researcher": {
      "model": "openai/gpt-5.4"
    },
    "gsd-research-synthesizer": {
      "model": "openai/gpt-5.4"
    },
    "gsd-codebase-mapper": {
      "model": "openai/gpt-5.4"
    },
    "gsd-executor": {
      "model": "openai/gpt-5.4"
    },
    "gsd-debugger": {
      "model": "openai/gpt-5.4"
    },
    "gsd-verifier": {
      "model": "openai/gpt-5.4"
    },
    "gsd-integration-checker": {
      "model": "openai/gpt-5.4"
    }
  }
