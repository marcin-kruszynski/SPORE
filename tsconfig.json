{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "references",
    "tmp",
    ".spore",
    "data",
    "artifacts"
  ]
}
